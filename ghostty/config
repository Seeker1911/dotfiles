# Comments start with a `#` and are only valid on their own line.
# CLI actions: (can be proceeded with -h)
# +help(shows the following), +list-keybinds +list-fonts, +list-actions, +show-config, +validate-config +list-themes, +list-colors +crash-report

theme = cyberdream-light

keybind = ctrl+z=close_surface
keybind = super+shift+l=new_split:right
keybind = super+shift+h=new_split:left
keybind = super+alt+l=goto_split:right
keybind = super+alt+h=goto_split:left
keybind = super+ctrl+right=resize_split:right,100
keybind = super+ctrl+left=resize_split:left,100

keybind = global:cmd+s=toggle_quick_terminal
keybind = global:super+shift+t=toggle_visibility

background-opacity = 0.90
# background-image = /Users/michaelmead/Library/Mobile Documents/com~apple~CloudDocs/Documents/photos/wallpapers/ghostty_background.jpg
background-image-fit = cover
background-blur = macos-glass-clear
background-blur-radius = 05 
split-divider-color = #EF630C
# unfocused-split-fill = #acaaaa
unfocused-split-opacity = 0.7

split-divider-color = #EF630C
confirm-close-surface = false
quit-after-last-window-closed = true
quick-terminal-size = 40%
quick-terminal-autohide = false
# shell-integration = zsh
shell-integration-features = sudo

macos-titlebar-style = transparent 
macos-option-as-alt = true

macos-icon = custom-style
macos-icon-frame = plastic
macos-icon-ghost-color = #E67B0E
macos-icon-screen-color = #386C44

mouse-hide-while-typing = true

font-family = JetBrainsMono Nerd Font Mono
font-size = 15
# ss01: != and ===
font-feature = "ss01"
# ss02: <= and >=
font-feature = "ss02"
# ss03: -> and ~>
font-feature = "ss03"
# ss04: <> and </>
font-feature = "ss04"
# liga: //, ..., ||
font-feature = "liga"
font-thicken = false

window-decoration = true
window-padding-x = 10 
window-padding-y = 10 
window-inherit-working-directory = true
window-theme = system
window-save-state = always
window-padding-color = background

quit-after-last-window-closed = true

# cursor-invert-fg-bg = true
cursor-style = block
# cursor-color = white

clipboard-read = "allow"
clipboard-paste-protection = false

quick-terminal-position = center 
keybind = shift+enter=text:\n
confirm-close-surface = false
clipboard-read = allow
copy-on-select = true
