{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git status > /tmp/claude-git-context.txt && echo 'Development context loaded'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/skill-simple-instruction-hook.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-compact-handover.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "peek-aws-logs@peek-claude-marketplace": true,
    "atlassian@claude-plugins-official": true,
    "mempalace@mempalace": true
  },
  "extraKnownMarketplaces": {
    "peek-claude-marketplace": {
      "source": {
        "source": "directory",
        "path": "/Users/michaelmead/workspaces/peek-claude-marketplace"
      }
    },
    "mempalace": {
      "source": {
        "source": "github",
        "repo": "milla-jovovich/mempalace"
      }
    }
  },
  "effortLevel": "high"
}
